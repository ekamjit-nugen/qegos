# =============================================
# QEGOS Environment Configuration
# =============================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# --- Application ---
NODE_ENV=development
PORT=5000
API_VERSION=v1

# --- MongoDB ---
MONGODB_URI=mongodb://localhost:27017/qegos-dev

# --- Redis ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# --- JWT ---
JWT_ACCESS_SECRET=your-access-token-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-token-secret-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# --- Encryption (AES-256-GCM for TFN and sensitive fields) ---
ENCRYPTION_KEY=your-32-byte-hex-encryption-key-here

# --- Twilio (OTP) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# --- CSRF ---
CSRF_SECRET=your-csrf-secret-min-32-chars

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# --- Logging ---
LOG_LEVEL=debug

# --- MFA ---
MFA_ISSUER=QEGOS
