# QEGOS Mobile — environment variables
#
# Copy to `.env` (gitignored) and fill in real values before running on a
# device. Values prefixed with EXPO_PUBLIC_ are inlined into the JS bundle
# at build time — do not put secrets here.

# API base URL. Must be reachable from the device on its network.
# Dev on a real device: use an ngrok/cloudflared tunnel or your LAN IP
#   e.g. http://192.168.1.42:5001/api/v1
# Simulator/emulator: localhost generally works except on Android emulator
#   where 10.0.2.2 replaces localhost.
EXPO_PUBLIC_API_URL=http://localhost:5001/api/v1

# Stripe publishable key (test mode for dev, live mode for prod).
# The backend also returns a publishable key per /pay response; this one
# bootstraps the StripeProvider before the first payment call.
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
